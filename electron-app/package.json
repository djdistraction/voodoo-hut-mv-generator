{
  "name": "htxpunk-mv-generator",
  "version": "1.0.0",
  "description": "HTXpunk Music Video Generator - Desktop App",
  "main": "main.js",
  "author": "HTXpunk Productions",
  "license": "Proprietary",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "dependencies": {
    "electron-is-dev": "^2.0.0"
  },
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4"
  },
  "build": {
    "appId": "tv.thevoodoohut.mvgenerator",
    "productName": "HTXpunk MV Generator",
    "files": [
      "main.js",
      "preload.js",
      "setup.html",
      "public/**/*",
      "backend/**/*",
      "!backend/storage/**/*",
      "!backend/__pycache__/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "HTXpunk MV Generator"
    },
    "mac": {
      "target": ["dmg", "zip"]
    },
    "linux": {
      "target": ["AppImage"]
    }
  }
}
