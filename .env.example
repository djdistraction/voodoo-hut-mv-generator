# ─── LLM (Groq — free tier) ──────────────────────────────────────────────────
# Sign up free at console.groq.com
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Image Generation (Gemini 2.5 Flash Image — free tier) ─────────────────
# Sign up free at aistudio.google.com (500 images/day, no credit card needed)
# REQUIRED for production. Set IMAGE_BACKEND=placeholder for dev-only offline mode.
GEMINI_API_KEY=AIzaSy_...
# Image backend: "gemini" (default, production) | "placeholder" (dev/offline only)
IMAGE_BACKEND=gemini

# ─── Audio Transcription (local Whisper — no key needed) ─────────────────────
# Options: tiny (fastest) | base | small | medium (most accurate on CPU)
WHISPER_MODEL=base

# ─── Storage (local filesystem — no account needed) ──────────────────────────
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage

# ─── Database (SQLite — no server needed) ────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./voodoo.db

# ─── Task Queue (in-memory — no Redis needed) ────────────────────────────────
CELERY_BROKER_URL=memory://
CELERY_RESULT_BACKEND=cache+memory://

# ─── Video Generation ────────────────────────────────────────────────────────
# "ffmpeg"   = free Ken Burns slideshow (no GPU, no Node — the working default).
#              Uses system ffmpeg, or the bundled imageio-ffmpeg binary.
# "remotion" = React/Remotion render (needs Node + remotion-composer installed).
# "runway"   = RunwayML Gen-4 (experimental; falls back to ffmpeg for now).
VIDEO_BACKEND=ffmpeg
VIDEO_FPS=25
CLIP_DURATION=5
OUTPUT_RESOLUTION=1920x1080

# Only needed if VIDEO_BACKEND=runway
RUNWAY_API_KEY=

# ─── Future: paid/cloud upgrades ─────────────────────────────────────────────
# Uncomment and fill these in when you're ready to deploy or upgrade quality

# Cloudflare R2 (set STORAGE_BACKEND=r2)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=voodoo-mv

# Supabase (set DATABASE_URL=postgresql+asyncpg://...)
# DATABASE_URL=postgresql+asyncpg://postgres:[password]@db.[ref].supabase.co:5432/postgres

# Upstash Redis (set CELERY_BROKER_URL=rediss://...)
# CELERY_BROKER_URL=rediss://:[password]@[host]:6379
