# ─── LLM (Groq — free tier) ──────────────────────────────────────────────────
# Sign up free at console.groq.com
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Image Generation ────────────────────────────────────────────────────────
# Choose a backend with IMAGE_BACKEND:
#   "cloudflare"  — Workers AI FLUX.1-schnell, FREE daily allocation (recommended)
#   "gemini"      — Gemini/Imagen, requires a BILLING-ENABLED Google project
#   "placeholder" — offline render, dev/testing only (no API, $0)
IMAGE_BACKEND=cloudflare

# Cloudflare Workers AI (free tier). Account ID from dash.cloudflare.com →
# Workers & Pages (right sidebar). Token: My Profile → API Tokens → Create Token
# → permission Account · Workers AI · Edit.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Gemini/Imagen (only if IMAGE_BACKEND=gemini). NOTE: image generation on Gemini
# requires a billing-enabled project — the free tier does NOT include it.
GEMINI_API_KEY=

# ─── Audio Transcription (local Whisper — no key needed) ─────────────────────
# Options: tiny (fastest) | base | small | medium (most accurate on CPU)
WHISPER_MODEL=base

# ─── Storage (local filesystem — no account needed) ──────────────────────────
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage

# ─── Database (SQLite — no server needed) ────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./voodoo.db

# ─── Task Queue (in-memory — no Redis needed) ────────────────────────────────
CELERY_BROKER_URL=memory://
CELERY_RESULT_BACKEND=cache+memory://

# ─── Video Generation ────────────────────────────────────────────────────────
# "ffmpeg"   = free Ken Burns slideshow (no GPU, no Node — the working default).
#              Uses system ffmpeg, or the bundled imageio-ffmpeg binary.
# "modal"    = AI image-to-video + lip-sync on Modal serverless GPUs (see MODAL_SETUP.md).
# "remotion" = React/Remotion render (needs Node + remotion-composer installed).
VIDEO_BACKEND=ffmpeg
VIDEO_FPS=25
CLIP_DURATION=5
OUTPUT_RESOLUTION=1920x1080

# ─── Modal serverless GPU (only if VIDEO_BACKEND=modal) ──────────────────────
# Self-hosted image-to-video + lip-sync on Modal's cloud GPUs. Free monthly
# credits. Set up on the deploying machine: `pip install modal && modal token new`.
LIPSYNC_ENABLED=true
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Only needed if VIDEO_BACKEND=runway
RUNWAY_API_KEY=

# ─── Future: paid/cloud upgrades ─────────────────────────────────────────────
# Uncomment and fill these in when you're ready to deploy or upgrade quality

# Cloudflare R2 (set STORAGE_BACKEND=r2)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=voodoo-mv

# Supabase (set DATABASE_URL=postgresql+asyncpg://...)
# DATABASE_URL=postgresql+asyncpg://postgres:[password]@db.[ref].supabase.co:5432/postgres

# Upstash Redis (set CELERY_BROKER_URL=rediss://...)
# CELERY_BROKER_URL=rediss://:[password]@[host]:6379
